{
  "name": "ai-travel-companion",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "description": "Hebrew AI travel companion with Google Maps, group chat, and Waze navigation.",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "qa": "powershell -ExecutionPolicy Bypass -File scripts/qa.ps1",
    "dev": "echo \"Run apps separately after dependencies are installed\"",
    "build": "node scripts/build.mjs",
    "start": "node apps/api/dist/server.js",
    "icons:pwa": "powershell -ExecutionPolicy Bypass -File scripts/generate-pwa-icons.ps1",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:whatsapp": "node scripts/smoke-whatsapp-readiness.mjs",
    "smoke:agent-provider": "node scripts/smoke-agent-provider-readiness.mjs",
    "smoke:google-places-live": "node scripts/smoke-google-places-live.mjs",
    "smoke:google-routes-live": "node scripts/smoke-google-routes-live.mjs",
    "agent:regression": "node scripts/kodi-agent-regression.mjs",
    "notifications:vapid": "node scripts/generate-vapid-keys.mjs",
    "db:apply-schema": "node scripts/apply-supabase-schema.mjs",
    "db:apply-grants": "node scripts/apply-supabase-grants.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "postgres": "^3.4.9"
  }
}
